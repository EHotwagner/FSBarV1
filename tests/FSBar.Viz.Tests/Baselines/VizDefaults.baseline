namespace FSBar.Viz

/// Default values for visualization state.
/// Lives in its own file (after UnitGlyphPalettes) so `defaultConfig.GlyphStyle`
/// can reference `UnitGlyphPalettes.defaults` without a forward reference.
module VizDefaults =
    val defaultViewState: ViewState
    val defaultEconomy: EconomyData
    val defaultConfig: VizConfig
