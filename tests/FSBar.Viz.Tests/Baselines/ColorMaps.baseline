namespace FSBar.Viz

/// Built-in color schemes for map layer visualization.
module ColorMaps =
    /// Black to white gradient.
    val grayscale: ColorScheme
    /// Blue (water) to green (low) to brown (mid) to white (peak) terrain gradient.
    val terrain: ColorScheme
    /// Blue (low) to yellow (mid) to red (high) heat gradient.
    val heatMap: ColorScheme
    /// Red (false/0) and green (true/1) binary scheme.
    val binary: ColorScheme
    /// Returns the default color scheme for a given layer kind.
    val colorSchemeFor: LayerKind -> ColorScheme
